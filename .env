# ── Build-time ────────────────────────────────────────────────
# Penpot version to build from: a release tag (2.13.3) or branch (develop, mcp-prod)
PENPOT_VERSION=develop

# ── Server binding ────────────────────────────────────────────
# Address the server binds to (0.0.0.0 for Docker)
PENPOT_MCP_SERVER_LISTEN_ADDRESS=0.0.0.0
# Hostname clients use to reach the server
PENPOT_MCP_SERVER_ADDRESS=localhost

# ── Ports ─────────────────────────────────────────────────────
# HTTP/SSE port for MCP client connections (/mcp, /sse)
PENPOT_MCP_SERVER_PORT=4401
# WebSocket port for Penpot plugin bridge
PENPOT_MCP_WEBSOCKET_PORT=4402
# TCP REPL port for development/debugging
PENPOT_MCP_REPL_PORT=4403

# ── Logging ──────────/─────────────────────────────────────────
# Log level: trace | debug | info | warn | error | fatal
PENPOT_MCP_LOG_LEVEL=info
# Directory for log files (inside container)
PENPOT_MCP_LOG_DIR=/app/logs

# ── Runtime modes ─────────────────────────────────────────────
# Disable local filesystem access (true | false)
PENPOT_MCP_REMOTE_MODE=false
# Enable multi-user mode (true | false)
MULTI_USER=false
